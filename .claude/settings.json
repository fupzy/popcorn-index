{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git push)",
      "Bash(git push *)"
    ],
    "allow": [
      "Bash(dotnet build)",
      "Bash(dotnet build *)",
      "Bash(dotnet test)",
      "Bash(dotnet test *)",
      "Bash(npm run build)",
      "Bash(npm run build *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run test:ci)",
      "Bash(npm run test:ci *)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(ng build)",
      "Bash(ng build *)",
      "Bash(ng test)",
      "Bash(ng test *)",
      "Bash(ng lint)",
      "Bash(ng lint *)"
    ]
  }
}
