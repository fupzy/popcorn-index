{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "Postgresql": "server=%POSTGRES_HOST%;port=%POSTGRES_PORT%;database=%POSTGRES_DB%;userId=%POSTGRES_USER%;password=%POSTGRES_PASSWORD%;"
  },
  "AllowedHosts": "*",
  "Swagger": {
    "DocumentTitle": "Popcorn Index"
  },
  "Utilities": {
    "PostgreSqlSchema": "popcorn-index"
  }
}
